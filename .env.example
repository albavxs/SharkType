# Copy this file to .env.local for local development.
# In Vercel, add the same values in the project Environment Variables screen
# and redeploy after every NEXT_PUBLIC_* change.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_public_key

# Legacy fallback still supported by SharkType for older deployments.
# Prefer NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY for new setups.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_legacy_anon_key

NEXT_PUBLIC_SITE_URL=http://localhost:3000
